# ================================================================
# DK-DE-OnPrem-CustomPlatform
# Fichier     : .env.example
# Description : Modèle de configuration des variables d'environnement
#
# Instructions :
#   1. Copier ce fichier vers .env  (cp .env.example .env)
#   2. Remplir chaque variable avec les valeurs réelles
#   3. Ne JAMAIS versionner .env (déjà dans .gitignore)
#   4. Les valeurs PostgreSQL du Data Warehouse (DW_*) doivent
#      correspondre EXACTEMENT à celles stockées dans Vault
#      (secret/postgres), sinon les DAGs ne pourront pas se connecter.
# ================================================================

# ----------------------------------------------------------------
# PostgreSQL : compte interne Airflow (metadata)
# ----------------------------------------------------------------
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=airflow

# ----------------------------------------------------------------
# PostgreSQL : Data Warehouse (Gold / customplatform)
# Doit correspondre au secret Vault secret/postgres
# ----------------------------------------------------------------
DW_USER=
DW_PASSWORD=
DW_DBNAME=customplatform

# ----------------------------------------------------------------
# Airflow : clés de sécurité
# FERNET_KEY : générer avec
#   docker run --rm apache/airflow:2.8.1-python3.11 \
#     python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# SECRET_KEY : générer avec
#   docker run --rm apache/airflow:2.8.1-python3.11 \
#     python -c "import secrets; print(secrets.token_hex(32))"
# ----------------------------------------------------------------
AIRFLOW_FERNET_KEY=
AIRFLOW_SECRET_KEY=

# ----------------------------------------------------------------
# MinIO : Data Lake (S3-compatible)
# ----------------------------------------------------------------
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# ----------------------------------------------------------------
# HashiCorp Vault : token racine (mode dev)
# Générer avec
#   docker run --rm apache/airflow:2.8.1-python3.11 \
#     python -c "import secrets; print(secrets.token_urlsafe(24))"
# ----------------------------------------------------------------
VAULT_ROOT_TOKEN=

# ----------------------------------------------------------------
# Mots de passe des comptes de service
# ----------------------------------------------------------------
AIRFLOW_PASSWORD=
PBI_SERVICE_PASSWORD=
MONITORING_PASSWORD=
DATA_ACCESS_PASSWORD=
