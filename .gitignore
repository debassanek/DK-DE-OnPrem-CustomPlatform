# ================================================================
# DK-DE-OnPrem-CustomPlatform : .gitignore
# ================================================================

# ----------------------------------------------------------------
# Secrets et variables d'environnement
# ----------------------------------------------------------------
.env
.env.local
.env.*.local
.env.production
.env.new
*.env
!.env.example

# ----------------------------------------------------------------
# Données brutes et fichiers volumineux
# ----------------------------------------------------------------
data/
*.csv
*.xlsx
*.xls
*.parquet
*.zip
*.log
*.json
!**/seeds/**/*.json
!dbt/**/*.json

# ----------------------------------------------------------------
# Logs Airflow
# ----------------------------------------------------------------
airflow/logs/
logs/

# ----------------------------------------------------------------
# Python
# ----------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
venv/
env/
.venv/
dist/
build/
*.egg-info/

# ----------------------------------------------------------------
# Docker et dbt
# ----------------------------------------------------------------
postgres_data/
minio_data/
dbt/target/
dbt/logs/
dbt/dbt_packages/
dbt/profiles.yml
.user.yml

# ----------------------------------------------------------------
# Vault (scripts versionnés, données et tokens exclus)
# ----------------------------------------------------------------
vault/data/
vault/*.token

# ----------------------------------------------------------------
# Fichiers temporaires
# ----------------------------------------------------------------
*.tmp
*.bak

# ----------------------------------------------------------------
# Système : Windows / macOS / Linux
# ----------------------------------------------------------------
Thumbs.db
Desktop.ini
.DS_Store

# ----------------------------------------------------------------
# IDE / Éditeurs
# ----------------------------------------------------------------
.vscode/
.idea/